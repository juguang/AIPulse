# Database (SQLite, file stored at project root)
DATABASE_URL=sqlite+aiosqlite:///./aipulse.db

# DeepSeek API (get your key at https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash

# Server
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
API_HOST=0.0.0.0
API_PORT=8000
ENV=development

# AI Pipeline
# AI_PIPELINE_BATCH_SIZE=5
# AI_PIPELINE_POLL_INTERVAL=60

# Crawler
# CRAWL_INTERVAL_MINUTES=30
# CRAWL_MAX_AGE_DAYS=3

# HuggingFace (optional, for HF Papers)
# HF_TOKEN=your_hf_token_here
