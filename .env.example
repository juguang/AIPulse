# PostgreSQL (local: brew install postgresql@16 && brew services start postgresql@16 && createdb aipulse)
DATABASE_URL=postgresql+asyncpg://localhost:5432/aipulse

# DeepSeek API (get your key at https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Server
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
API_HOST=0.0.0.0
API_PORT=8000
ENV=development

# HuggingFace token (optional, for HF Papers)
# HF_TOKEN=your_hf_token_here
